# TaskDrip — Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git (it's already in .gitignore)

# ──────────────────────────────────────────────
# Required (for AI processing)
# ──────────────────────────────────────────────

# OpenAI API Key — required for AI task processing
# Get one at: https://platform.openai.com/api-keys
# You need an OpenAI account with billing enabled
# Cost estimate: ~$2.60/month for 50 tasks/day (GPT-4o-mini)
# See docs/openai-setup.md for full cost analysis
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# Required (for Postgres persistence — post-MVP)
# ──────────────────────────────────────────────

# Database URL — Neon/Postgres connection string
# Only needed when running the Postgres version (see DON-13)
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Get one at: https://neon.tech (free tier: 0.5GB storage)
# DATABASE_URL=

# ──────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────

# Demo mode — when OPENAI_API_KEY is not set, the app uses mock AI responses
# so the full task lifecycle can be demonstrated without external APIs.
# Set to "false" to force the real OpenAI path (will error if no key configured).
# Set to "true" to always use demo responses even if a key is present.
# Default: auto (demo mode when no valid key)
# DEMO_MODE=false

# Database path — SQLite only (local / ephemeral)
# Default: ./data/app.db (relative to project root)
# NOTE: On Vercel, SQLite data is EPHEMERAL — it resets on every
# deployment and function cold start. For persistent data, migrate
# to Postgres (see DEPLOY.md).
# DATABASE_URL=file:./data/taskdrip.db