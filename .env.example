# TaskDrip — Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git (it's already in .gitignore)

# ──────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────

# OpenAI API Key — required for AI task processing
# Get one at: https://platform.openai.com/api-keys
# You need an OpenAI account with billing enabled
# Cost estimate: ~$2.60/month for 50 tasks/day (GPT-4o-mini)
# See docs/openai-setup.md for full cost analysis
OPENAI_API_KEY=sk-your-key-here

# ──────────────────────────────────────────────
# Optional
# ──────────────────────────────────────────────

# Database path — SQLite only (local / ephemeral)
# Default: ./data/app.db (relative to project root)
# NOTE: On Vercel, SQLite data is EPHEMERAL — it resets on every
# deployment and function cold start. For persistent data, migrate
# to Postgres (see DEPLOY.md).
# DATABASE_URL=file:./data/taskdrip.db